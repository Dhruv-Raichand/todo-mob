rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection - FIXED permission
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Tasks collection
    match /tasks/{taskId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // ❤️ KEY FIX HERE: Allow chairman or assigned faculty to update/delete
      allow update, delete: if request.auth != null &&
        (resource.data.chairmanId == request.auth.uid ||
         (resource.data.assignedFaculty != null && request.auth.uid in resource.data.assignedFaculty));
      
      // Extension requests subcollection
      match /extensionRequests/{requestId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null;
        allow delete: if request.auth != null;
      }
      
      // Comments subcollection
      match /comments/{commentId} {
        allow read, create: if request.auth != null;
        allow delete: if request.auth.uid == resource.data.userId;
      }
    }
  }
}
